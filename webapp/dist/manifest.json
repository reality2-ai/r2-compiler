  "ensembles": [
    {
      "kind": "ensemble",
      "slug": "rocker-sensor",
      "path": "catalogue/ensembles/rocker-sensor",
      "name": "rocker-sensor",
      "class": "nz.ac.auckland.rocker          # shared deployment class",
      "version": "0.2.0",
      "description": "Sensor role-ensemble: the ESP32 sample pipeline on each rig device. Reads calibrated triaxial acceleration, writes it to an SD ring, streams it to the controller, and owns the on-device capture state machine + event-mark sidecar. Deployment-specific in exactly two places \u2014 the sensing plugin and the domain (accelerometer) sentant.",
      "compile_target": "[esp32-s3]            # candidate: esp32-c6",
      "plugins": [
        {
          "kind": "plugin",
          "category": "sensor",
          "slug": "lis2dh",
          "path": "catalogue/ensembles/rocker-sensor/plugins/sensor/lis2dh",
          "name": "lis2dh",
          "version": "0.1.0",
          "description": "STMicroelectronics LIS2DH 3-axis MEMS accelerometer over I\u00b2C. Provides the generic triaxial-accel capability for r2-workshop's dfr1117 carrier (sourced via DFRobot SEN0224 Gravity I\u00b2C module). 10-bit data, \u00b12/4/8/16 g, ODR up to 5.3 kHz. Capability-aligned peer to adxl355 (SPI, 20-bit, higher precision) \u2014 same capability provided, different chip + bus per R2-PLUGIN \u00a710 swap lever.",
          "modes": {
            "aot": true,
            "nif": false,
            "web": false
          },
          "provides": [
            "ai.reality2.cap.accel.triaxial",
            "ai.reality2.cap.accel.triaxial.10bit"
          ],
          "requires": [
            "r2.hw.i2c"
          ],
          "commands": [
            "init",
            "read",
            "read_burst",
            "set_odr",
            "set_range",
            "set_offset",
            "sleep"
          ],
