# Build outputs
/target/
**/target/
out/
*.bin
*.elf

# Per-carrier build state (orchestrator output)
/out/

# Cargo
Cargo.lock
!/crates/**/Cargo.lock
!/orchestrator/Cargo.lock

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*~

# Local config & secrets — per PROCESS.md §5
wifi_config.toml
*.priv
*.priv.bin
**/tg_signer/
.env
.env.*
!.env.example

# Claude Code session artefacts
.claude/
*.claude_session

# Logs
*.log
logs/

# Local orchestrator data
orchestrator/data/
~/.config/r2-compiler/

# Apiaries — independent git repos per SPEC-APIARY-LAYOUT §2.1. The
# r2-composer outer repo MUST NOT track them; each apiary the operator
# creates lives as its own git repo (and may be pushed to their own
# GitHub namespace per SPEC-APIARY-CREATE §2.5). The single exception
# is `apiaries/rocker-rig` — the BUNDLED worked example referenced by
# SPEC-APIARY-COMPOSE §12 that ships with r2-composer for spec
# conformance + as the C-1 canvas test fixture.
apiaries/*
!apiaries/rocker-rig
!apiaries/rocker-rig/**
